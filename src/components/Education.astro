---
const courses = ["Applied AI", "Software Design & Architecture", "Embedded Systems", "Big Data Engineering", "Data Structures & Algorithms"];
const activities = ["Taekwondo Black Belt (1st Dan)", "Piano", "Research Residency @ Northeastern"];
---

<section id="education" class="py-24 px-6 max-w-5xl mx-auto">
  <div class="animate-fade-in">
    <p class="font-mono text-accent text-sm tracking-widest uppercase mb-2">05 &middot; Education</p>
    <h2 class="font-mono text-3xl md:text-4xl font-bold text-foreground mb-8">Academic Background</h2>
  </div>

  <div class="animate-fade-in animate-fade-in-delay-1 bg-surface border border-border rounded-xl p-6">
    <div class="flex flex-col md:flex-row md:items-start md:justify-between gap-2 mb-4">
      <div>
        <h3 class="font-mono text-lg font-semibold text-foreground">Computer Engineering</h3>
        <p class="text-muted text-sm">Universidad de los Andes &middot; Santiago, Chile</p>
      </div>
      <span class="font-mono text-xs text-accent whitespace-nowrap px-3 py-1 bg-accent/10 rounded-full">2022 &ndash; Present</span>
    </div>

    <div class="grid sm:grid-cols-2 gap-4 mt-6">
      <div>
        <h4 class="font-mono text-xs text-accent tracking-wider uppercase mb-3">Relevant Coursework</h4>
        <ul class="space-y-2">
          {courses.map(course => (
            <li class="flex items-center gap-2 text-muted text-sm">
              <svg class="w-3 h-3 text-accent flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 12h14"></path></svg>
              {course}
            </li>
          ))}
        </ul>
      </div>
      <div>
        <h4 class="font-mono text-xs text-accent tracking-wider uppercase mb-3">Beyond the Classroom</h4>
        <ul class="space-y-2">
          {activities.map(activity => (
            <li class="flex items-center gap-2 text-muted text-sm">
              <svg class="w-3 h-3 text-accent flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 12h14"></path></svg>
              {activity}
            </li>
          ))}
        </ul>
      </div>
    </div>
  </div>
</section>
