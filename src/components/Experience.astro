---
interface Experience {
  role: string;
  organization: string;
  period: string;
  description: string[];
  tags: string[];
}

const experiences: Experience[] = [
  {
    role: 'Research Fellow',
    organization: 'Northeastern University · Boston, MA',
    period: '2025',
    description: [
      'Analyzing CPR quality using functional near-infrared spectroscopy (fNIRS) and AI-driven signal processing.',
      'Developing coupled oscillator models to study physiological dynamics during cardiac arrest resuscitation.',
      'Building ML pipelines for real-time interpretation of biomedical signals.',
    ],
    tags: ['fNIRS', 'Signal Processing', 'AI/ML', 'Python'],
  },
  {
    role: 'Assistant Coordinator',
    organization: 'Universidad de los Andes · Santiago, Chile',
    period: '2024 – Present',
    description: [
      'Managing course logistics and coordinating review teams for Engineering and Mathematics courses.',
      'Leading academic support initiatives and mentoring junior students.',
    ],
    tags: ['Leadership', 'Curriculum Design', 'Mentoring'],
  },
];
---

<section id="experience" class="py-24 px-6 max-w-5xl mx-auto">
  <div class="animate-fade-in">
    <p class="font-mono text-accent text-sm tracking-widest uppercase mb-2">03 · Experience</p>
    <h2 class="font-mono text-3xl md:text-4xl font-bold text-foreground mb-8">Research &amp; Leadership</h2>
  </div>

  <div class="relative">
    <div class="absolute left-0 md:left-6 top-0 bottom-0 w-px bg-border hidden md:block"></div>

    <div class="space-y-12">
      {experiences.map((exp, i) => {
        const delay = i;
        return (
        <div class={`animate-fade-in animate-fade-in-delay-${delay} relative pl-0 md:pl-16`}>
          <div class="hidden md:block absolute left-4 top-1 w-4 h-4 rounded-full bg-accent border-4 border-deep"></div>

          <div class="bg-surface border border-border rounded-xl p-6">
            <div class="flex flex-col md:flex-row md:items-start md:justify-between gap-2 mb-4">
              <div>
                <h3 class="font-mono text-lg font-semibold text-foreground">{exp.role}</h3>
                <p class="text-muted text-sm">{exp.organization}</p>
              </div>
              <span class="font-mono text-xs text-accent whitespace-nowrap px-3 py-1 bg-accent/10 rounded-full">{exp.period}</span>
            </div>

            <ul class="space-y-2 mb-4">
              {exp.description.map(item => (
                <li class="flex items-start gap-2 text-muted text-sm">
                  <span class="text-accent mt-1.5 flex-shrink-0">
                    <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 12h14"></path></svg>
                  </span>
                  {item}
                </li>
              ))}
            </ul>

            <div class="flex flex-wrap gap-2">
              {exp.tags.map(tag => (
                <span class="px-2.5 py-1 text-xs font-mono bg-card border border-border rounded text-muted">{tag}</span>
              ))}
            </div>
          </div>
        </div>
      );
      })}
    </div>
  </div>
</section>
