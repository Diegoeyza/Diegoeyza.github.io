---
import TerminalText from './TerminalText.astro';
---

<section class="min-h-screen flex flex-col justify-center items-center px-6 relative overflow-hidden">
  <div class="absolute inset-0 pointer-events-none">
    <div class="absolute top-1/4 left-1/4 w-96 h-96 bg-accent/5 rounded-full blur-3xl"></div>
    <div class="absolute bottom-1/4 right-1/4 w-96 h-96 bg-violet/5 rounded-full blur-3xl"></div>
  </div>

  <div class="relative z-10 max-w-3xl mx-auto text-center">
    <p class="font-mono text-accent text-sm tracking-widest uppercase mb-6">
      AI Research Engineer
    </p>

    <h1 class="font-mono text-4xl md:text-6xl lg:text-7xl font-bold leading-tight mb-6">
      <span class="text-foreground">Diego</span>
      <span class="text-accent"> Eyzaguirre</span>
    </h1>

    <p class="text-lg md:text-xl text-muted max-w-2xl mx-auto mb-8 leading-relaxed">
      Bridging <span class="text-foreground font-semibold">agentic AI</span> and
      <span class="text-foreground font-semibold">edge intelligence</span> —
      from research to deployed systems.
    </p>

    <TerminalText
      strings={["Building agents that run on cheap hardware", "Exploring TinyML for biomedical signals", "Full-stack AI systems with RAG at the core"]}
      prefix="$  "
      className="mx-auto max-w-xl text-left bg-surface/80 border border-border rounded-lg p-4 backdrop-blur-sm"
    />

    <div class="flex gap-4 justify-center mt-10">
      <a href="mailto:deyzaguirre1@miuandes.cl" class="inline-flex items-center gap-2 px-6 py-3 bg-accent/10 border border-accent/30 text-accent font-mono text-sm rounded-lg hover:bg-accent/20 transition-all duration-300">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"></path></svg>
        Email
      </a>
      <a href="https://www.linkedin.com/in/diego-eyzaguirre-bas-302439338" target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-2 px-6 py-3 border border-border text-muted font-mono text-sm rounded-lg hover:text-foreground hover:border-foreground/30 transition-all duration-300">
        <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"></path></svg>
        LinkedIn
      </a>
      <a href="https://github.com/diegoeyza" target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-2 px-6 py-3 border border-border text-muted font-mono text-sm rounded-lg hover:text-foreground hover:border-foreground/30 transition-all duration-300">
        <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M12 0C5.374 0 0 5.373 0 12c0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23A11.509 11.509 0 0112 5.803c1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576C20.566 21.797 24 17.3 24 12c0-6.627-5.373-12-12-12z"></path></svg>
        GitHub
      </a>
    </div>
  </div>

  <div class="absolute bottom-8 left-1/2 -translate-x-1/2">
    <svg class="w-5 h-5 text-muted animate-bounce" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 14l-7 7m0 0l-7-7m7 7V3"></path></svg>
  </div>
</section>
