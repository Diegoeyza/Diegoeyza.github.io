---
const items = [
  {
    title: "Agentic AI and Edge Intelligence",
    desc: "Designing agentic workflows optimized for low-cost, decentralized hardware. Exploring how small models can coordinate autonomously on ESP32-class devices.",
    accent: "accent",
    svg: "M12 6v12m-3-2.818l.879.659c1.171.879 3.07.879 4.242 0 1.172-.879 1.172-2.303 0-3.182C13.536 12.219 12.768 12 12 12c-.725 0-1.45-.22-2.003-.659-1.106-.879-1.106-2.303 0-3.182s2.9-.879 4.006 0l.415.33M21 12a9 9 0 11-18 0 9 9 0 0118 0z",
  },
  {
    title: "Biomedical Signal Analysis",
    desc: "Research Fellow at Northeastern University analyzing CPR quality using fNIRS and AI. Developing ML pipelines for real-time physiological signal interpretation.",
    accent: "violet",
    svg: "M21 21l-5.197-5.197m0 0A7.5 7.5 0 105.196 5.196a7.5 7.5 0 0010.607 10.607z",
  },
  {
    title: "RAG and Knowledge Graphs",
    desc: "Building the RA Analyzer: an AI-powered system that extracts structured curriculum data from academic PDFs and builds interactive knowledge graphs with a Gemma 4 RAG agent.",
    accent: "accent",
    svg: "M12 6.042A8.967 8.967 0 006 3.75c-1.052 0-2.062.18-3 .512v14.25A8.987 8.987 0 016 18c2.305 0 4.408.867 6 2.292m0-14.25a8.966 8.966 0 016-2.292c1.052 0 2.062.18 3 .512v14.25A8.987 8.987 0 0018 18a8.967 8.967 0 00-6 2.292m0-14.25v14.25",
  },
  {
    title: "TinyML and Model Optimization",
    desc: "Designing small CNN topologies for ESP32-S3, comparing accuracy, size, and inference speed tradeoffs. Quantization and ONNX export for real-world embedded deployment.",
    accent: "violet",
    svg: "M9.75 17L9 20l-1 1h8l-1-1-.75-3M3 13h18M5 17h14a2 2 0 002-2V5a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z",
  },
];
---

<section id="research" class="py-24 px-6 max-w-5xl mx-auto">
  <div class="animate-fade-in">
    <p class="font-mono text-accent text-sm tracking-widest uppercase mb-2">01 &middot; Focus</p>
    <h2 class="font-mono text-3xl md:text-4xl font-bold text-foreground mb-8">Research and Engineering</h2>
  </div>

  <div class="grid md:grid-cols-2 gap-6">
    {items.map((item, i) => {
      const delay = Math.min(i + 1, 3);
      const bgClass = `bg-${item.accent}/10`;
      const textClass = `text-${item.accent}`;
      return (
        <div class={`animate-fade-in animate-fade-in-delay-${delay} bg-surface border border-border rounded-xl p-6 hover:border-accent/30 transition-colors duration-300`}>
          <div class={`w-10 h-10 rounded-lg ${bgClass} flex items-center justify-center mb-4`}>
            <svg class={`w-5 h-5 ${textClass}`} fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d={item.svg}></path></svg>
          </div>
          <h3 class="font-mono text-lg font-semibold text-foreground mb-2">{item.title}</h3>
          <p class="text-muted text-sm leading-relaxed">{item.desc}</p>
        </div>
      );
    })}
  </div>
</section>

<script>
  const observer = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if (entry.isIntersecting) {
        entry.target.classList.add('visible');
      }
    });
  }, { threshold: 0.1 });

  document.querySelectorAll('.animate-fade-in').forEach(el => observer.observe(el));
</script>
